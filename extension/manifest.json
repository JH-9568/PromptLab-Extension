{
  "manifest_version": 3,
  "name": "PromptLab Extension",
  "version": "0.1.0",
  "description": "Analyze and improve prompts on ChatGPT with PromptLab.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://promptlab-server.onrender.com/*"
  ],
  "action": {
    "default_title": "PromptLab",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "style.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
